{
  "name": "rag-interface",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "test": "node scripts/test/run-tests.mjs",
    "smoke:local": "node scripts/smoke/runners/local.mjs",
    "smoke:buttons": "node scripts/smoke/runners/buttons.mjs",
    "smoke:production": "node scripts/smoke/runners/production.mjs",
    "qa:manual": "node scripts/qa/manual-external.mjs",
    "qa:manual:auto": "node scripts/qa/manual-external.mjs --start-server",
    "cleanup:project": "node scripts/cleanup/project-processes.mjs --yes",
    "cleanup:project:dry-run": "node scripts/cleanup/project-processes.mjs --dry-run",
    "cleanup:artifacts": "node scripts/cleanup/local-artifacts.mjs --yes",
    "cleanup:artifacts:dry-run": "node scripts/cleanup/local-artifacts.mjs --dry-run",
    "audit:assets": "node scripts/audit/assets.mjs",
    "audit:docs": "node scripts/audit/docs.mjs",
    "audit:dead-code": "knip --include files,dependencies,unlisted,binaries,unresolved --no-progress",
    "audit:exports": "knip --exports --include-entry-exports --no-progress --max-show-issues 120",
    "release:evidence": "node scripts/release/evidence.mjs",
    "release:prepare": "node scripts/release/prepare.mjs",
    "verify:release": "node scripts/release/verify.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "archiver": "^7.0.1",
    "js-yaml": "^4.2.0",
    "natural": "^8.1.1",
    "next": "16.2.9",
    "react": "^18",
    "react-dom": "^18",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "swr": "^2.4.1"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.9",
    "knip": "^6.20.0",
    "playwright": "^1.61.0",
    "postcss": "8.5.15",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.22.4",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "8.5.15"
  }
}
